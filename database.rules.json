{
  "rules": {
    "board": {
      ".read": true,
      ".write": true
    },
    "presence": {
      ".read": true,
      ".write": true
    },
    "playerFruit": {
      ".read": true,
      ".write": true
    },
    "playerLastSeen": {
      ".read": true,
      ".write": true
    },
    "fruitCounter": {
      ".read": true,
      ".write": true
    },
    "memberProfiles": {
      ".read": true,
      ".write": false
    },
    "memberTotalScore": {
      ".read": true,
      ".write": true,
      "$uid": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "members": {
      ".read": false,
      ".write": false
    },
    "pushTokens": {
      ".read": false,
      ".write": true,
      "$uid": {
        ".validate": "newData.hasChildren(['token', 'platform', 'ts']) && newData.child('token').isString()"
      }
    },
    "reports": {
      ".read": false,
      ".write": true,
      "$reportId": {
        ".validate": "newData.hasChildren(['reporterId', 'targetId', 'reason', 'ts']) && newData.child('reason').isString() && newData.child('reason').val().length <= 300"
      }
    },
    "memberNicknames": {
      ".read": false,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
